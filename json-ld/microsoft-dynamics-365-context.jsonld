        },
        "closeprobability": {
          "@id": "crm:opportunity#closeprobability",
          "@type": "xsd:integer"
        },
        "estimatedclosedate": {
          "@id": "crm:opportunity#estimatedclosedate",
          "@type": "xsd:date"
        },
        "actualclosedate": {
          "@id": "crm:opportunity#actualclosedate",
          "@type": "xsd:date"
        },
        "stepname": {
