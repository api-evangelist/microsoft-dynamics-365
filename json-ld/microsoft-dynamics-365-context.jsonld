          "@type": "xsd:string"
        },
        "fullname": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "salutation": {
          "@id": "schema:honorificPrefix",
          "@type": "xsd:string"
        },
        "suffix": {
          "@id": "schema:honorificSuffix",
          "@type": "xsd:string"
        },
        "jobtitle": {
          "@id": "schema:jobTitle",
          "@type": "xsd:string"
        },
        "department": {
          "@id": "dynamics:contact#department",
